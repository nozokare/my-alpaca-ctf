{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "New Challenge",
      "type": "shell",
      "command": "./scripts/new-challenge.sh",
      "args": [
        "--type",
        "${input:type}",
        "--date",
        "${input:date}",
        "--title",
        "${input:title}",
        "--url",
        "${input:url}",
        "--connect",
        "${input:connect}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "type",
      "type": "pickString",
      "description": "Challenge type",
      "options": ["daily", "bside"],
      "default": "daily"
    },
    {
      "id": "date",
      "type": "promptString",
      "description": "Date (yyyymmdd, leave empty for today)",
      "default": ""
    },
    {
      "id": "title",
      "type": "promptString",
      "description": "Challenge title (slug is auto-generated)"
    },
    {
      "id": "url",
      "type": "promptString",
      "description": "Handout download URL (optional, leave empty to skip)",
      "default": ""
    },
    {
      "id": "connect",
      "type": "promptString",
      "description": "Connect string, e.g. nc host 1234 (optional, leave empty to skip)",
      "default": ""
    }
  ]
}
