{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Node: current file",
      "type": "node",
      "request": "launch",
      "program": "${fileBasename}",
      "envFile": "${fileDirname}/.env",
      "cwd": "${fileDirname}",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Python: current file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "envFile": "${fileDirname}/.env",
      "cwd": "${fileDirname}",
      "console": "integratedTerminal"
    }
  ]
}
