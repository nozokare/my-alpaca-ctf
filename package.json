{
  "scripts": {
    "alpaca:new": "node ./scripts/new-challenge.ts -i",
    "sage:jupyter": "scripts/run-sage-jupyter.sh --mount $INIT_CWD",
    "sage:run": "scripts/run-container.sh --rm -it sagemath/sagemath --mount $INIT_CWD -- sage",
    "radare2:run": "scripts/run-container.sh --rm -it radare2 --allow-no-aslr --mount $INIT_CWD -- r2",
    "radare2:build": "scripts/build-container.sh radare2",
    "pwndbg:run": "scripts/run-container.sh --rm -it pwndbg --allow-no-aslr --mount $INIT_CWD -- pwndbg",
    "pwndbg:build": "scripts/build-container.sh pwndbg",
    "postinstall": "lefthook install"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@dotenvx/dotenvx": "^1.59.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "lefthook": "^2.1.4"
  },
  "type": "module"
}
